#!/usr/bin/env sh

set -eu

HOOK_NAME='SessionEnd'
SCRIPT_DIR="$(CDPATH= cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(CDPATH= cd "${SCRIPT_DIR}/.." && pwd)"
ENTRYPOINT="${PLUGIN_ROOT}/scripts/invoke-hook-trigger.ps1"

if [ ! -f "$ENTRYPOINT" ]; then
    exit 0
fi

resolve_powershell() {
    for candidate in pwsh pwsh.exe powershell powershell.exe; do
        if command -v "$candidate" >/dev/null 2>&1; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

if ! POWERSHELL_BIN="$(resolve_powershell)"; then
    exit 0
fi

if [ "${OS:-}" = "Windows_NT" ]; then
    exec "$POWERSHELL_BIN" -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "$ENTRYPOINT" -HookName "$HOOK_NAME"
fi

exec "$POWERSHELL_BIN" -NoLogo -NoProfile -NonInteractive -File "$ENTRYPOINT" -HookName "$HOOK_NAME"
